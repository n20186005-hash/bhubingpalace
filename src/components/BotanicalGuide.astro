---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const bg = messages.botanicalGuide;
---

<section id="botanical-guide" class="section-padding" style="background: var(--bg-primary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mb-10 sm:mb-14">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-4" style="color: var(--text-primary);">
        {bg.title}
      </h2>
      <p class="text-base sm:text-lg max-w-2xl leading-relaxed" style="color: var(--text-secondary);">
        {bg.subtitle}
      </p>
    </div>

    <!-- Horizontal Scroll Container -->
    <div class="flex overflow-x-auto pb-8 snap-x snap-mandatory gap-6 scrollbar-hide">
      {bg.items.map((item) => (
        <div class="flex-none w-72 sm:w-80 snap-center rounded-2xl overflow-hidden shadow-sm" style="background: var(--bg-tertiary); border: 1px solid var(--border-color);">
          <div class="aspect-[4/3] w-full overflow-hidden">
            <img src={item.img} alt={item.name} loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-5">
            <h3 class="text-lg font-semibold mb-1" style="color: var(--text-primary);">{item.name}</h3>
            <p class="text-sm italic mb-3" style="color: var(--text-secondary);">{item.latin}</p>
            <div class="inline-block px-3 py-1 mb-3 rounded-full text-xs font-medium" style="background: rgba(15, 32, 21, 0.08); color: var(--accent);">
              🌸 {item.bloom}
            </div>
            <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
